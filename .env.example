# Shopify (sync de customers)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Modelo NOVO (Dev Dashboard, prod): app dá Client ID + Secret; o token é obtido
# via client credentials grant (~24h, renovado automático). Ver lib/shopify/token.ts.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Modelo legado/DEV: token estático (usado só se CLIENT_ID/SECRET não estiverem setados).
SHOPIFY_ADMIN_API_TOKEN=your-admin-api-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pivô V2 (28/04/2026) — default OFF até validação. Ver docs/sdd/PIVOT-V2.md
LRP_V2=false
CRON_DISABLED_V2=false

# F-V18 (Sprint 3 — 06/05/2026): cron diário de tags auto:lider/auto:influenciador.
# Gerar com: openssl rand -hex 32
# Vercel Cron envia automaticamente como `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=replace-with-openssl-rand-hex-32

# F-V18 (S5+): quando F-V03 entrar e popular subscription_status, ativar pra
# disparar recompute(sponsor_id) em tempo real ao mudar status.
LRP_V2_INVALIDATE_TAGS_ON_STATUS_CHANGE=false

# F-V07b (S5) — Cashin live. Default OFF até credenciais reais. Modos: mock|sandbox|live
LRP_V2_CASHIN_LIVE=false
CASHIN_MODE=mock
CASHIN_API_BASE_URL=https://api-sandbox.cashin.example
CASHIN_API_TOKEN=
CASHIN_WEBHOOK_TOKEN=

# F-V17 (S5) — SSO Shopify via App Proxy. Default OFF (rollout gradual).
# Setup: docs/sdd/features/F-V17-sso-shopify/SHOPIFY-SETUP.md
LRP_V2_SSO=false

# F-V07c (S5) — Dados Biohelp para validação automática de NF (TBD-27 — placeholders S2)
BIOHELP_CNPJ=12.345.678/0001-90
BIOHELP_RAZAO_SOCIAL=Biohelp

# F-V19 (22/05/2026) — Fluxo pré-cadastro Guru → LRP → Shopify.
# Ver docs/sdd/features/F-V19-fluxo-guru-pre-cadastro/SPEC.md
# Ver docs/wiki/runbooks/webhook-guru-debug.md (autenticação por api_token no body, NÃO HMAC)
LRP_V2_GURU_FLOW=false
# api_token gerado pelo painel Guru por config de webhook. Validado contra payload.api_token no body JSON.
GURU_WEBHOOK_API_TOKEN=dev_token_change_in_prod
# Slug da oferta no Guru (confirmado 22/05). URL checkout: clkdmg.site/subscribe/<slug>
# Confirmado 25/05: R$1.188 anual parcelado 12x s/ juros = R$99/mês (Léo confirmou).
GURU_OFFER_ID_CLUBE_MENSAL=membership-biohelp-nutrition-club
# Variant id confirmado 25/05 pelo Gabriel (id 7927880974426).
SHOPIFY_VAR_ASSINATURA_CLUBE=7927880974426
# Liga sync real Shopify (customer + draft order). Mantém false enquanto variant não existir.
SHOPIFY_SUBSCRIPTION_SYNC_LIVE=false
# Habilita /api/dev/simulate-guru (NUNCA true em produção).
DEV_SIMULATE_GURU=false

# F-V20 — CRM Absolut (outbound). Default OFF até Abner confirmar URL/token.
# Ver docs/sdd/features/F-V20-crm-absolut/SPEC.md
# Eventos: lead_novo (pré-cadastro de membro novo) e virou_cliente (1ª ativação paga).
# CRM_ABSOLUT_LIVE=false
# CRM_ABSOLUT_WEBHOOK_URL=
# CRM_ABSOLUT_TOKEN=

